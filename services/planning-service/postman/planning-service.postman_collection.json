              "  pm.response.to.have.status(200);",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Get Planning List (Filtered)",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/planning?planningStatus=PLANNED&vehicleId={{vehicleId}}&franchiseId={{franchiseId}}",
          "host": ["{{baseUrl}}"],
          "path": ["planning"],
          "query": [
            {
              "key": "planningStatus",
              "value": "PLANNED"
            },
            {
              "key": "vehicleId",
              "value": "{{vehicleId}}"
            },
            {
              "key": "franchiseId",
              "value": "{{franchiseId}}"
            }
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('status is 200/400', function () {",
              "  pm.expect([200, 400]).to.include(pm.response.code);",
              "});"
            ]
          }
        }
      ]
    },
