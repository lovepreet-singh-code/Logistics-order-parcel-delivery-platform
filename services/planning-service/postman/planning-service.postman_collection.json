  "item": [
    {
      "name": "Health Check",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/health",
          "host": ["{{baseUrl}}"],
          "path": ["health"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('status is 200', function () {",
              "  pm.response.to.have.status(200);",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Create Planning",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"orderId\": \"ORD-20260227-123001\",\n  \"vehicleId\": \"VEH-1001\",\n  \"franchiseId\": \"FR-001\",\n  \"scheduledPickupTime\": \"2026-03-01T10:00:00.000Z\",\n  \"scheduledDeliveryTime\": \"2026-03-01T16:30:00.000Z\",\n  \"routeSummary\": \"Mumbai Hub -> Pune DC via Expressway\",\n  \"estimatedDistanceKm\": 156,\n  \"estimatedDurationMinutes\": 390,\n  \"loadWeightKg\": 420,\n  \"planningStatus\": \"PLANNED\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/planning",
          "host": ["{{baseUrl}}"],
          "path": ["planning"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('status is 201', function () {",
              "  pm.response.to.have.status(201);",
              "});",
              "const jsonData = pm.response.json();",
              "if (jsonData && jsonData.data && jsonData.data._id) {",
              "  pm.collectionVariables.set('planningId', jsonData.data._id);",
              "}",
              "if (jsonData && jsonData.data && jsonData.data.planningNumber) {",
              "  pm.collectionVariables.set('planningNumber', jsonData.data.planningNumber);",
              "}"
            ]
          }
        }
      ]
    },
    {
      "name": "Get Planning List",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/planning",
          "host": ["{{baseUrl}}"],
          "path": ["planning"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
