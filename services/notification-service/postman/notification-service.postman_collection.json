{
  "info": {
    "name": "Notification Service",
    "_postman_id": "2c0a365e-c2aa-4f31-95d6-c4d8d6cc2a8f",
    "description": "Collection for notification-service endpoints.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Health Check",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/health",
          "host": ["{{baseUrl}}"],
          "path": ["health"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('status is 200', function () {",
              "  pm.response.to.have.status(200);",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Create Notification",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"userId\": \"USR-1001\",\n  \"relatedOrderId\": \"ORD-20260227-123001\",\n  \"title\": \"Order Created\",\n  \"message\": \"Your order has been created successfully.\",\n  \"type\": \"ORDER_CREATED\",\n  \"deliveryChannel\": \"PUSH\",\n  \"status\": \"PENDING\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/notifications",
          "host": ["{{baseUrl}}"],
          "path": ["notifications"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('status is 201', function () {",
              "  pm.response.to.have.status(201);",
              "});",
              "const jsonData = pm.response.json();",
              "if (jsonData && jsonData.data && jsonData.data._id) {",
              "  pm.collectionVariables.set('notificationMongoId', jsonData.data._id);",
              "}",
              "if (jsonData && jsonData.data && jsonData.data.notificationId) {",
              "  pm.collectionVariables.set('notificationId', jsonData.data.notificationId);",
              "}"
            ]
          }
        }
      ]
    },
    {
      "name": "Get Notifications",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/notifications",
          "host": ["{{baseUrl}}"],
          "path": ["notifications"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('status is 200', function () {",
              "  pm.response.to.have.status(200);",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Get Notifications (Filtered)",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/notifications?userId={{userId}}&status=PENDING&type=ORDER_CREATED",
          "host": ["{{baseUrl}}"],
          "path": ["notifications"],
          "query": [
            {
              "key": "userId",
              "value": "{{userId}}"
            },
            {
              "key": "status",
              "value": "PENDING"
            },
            {
              "key": "type",
              "value": "ORDER_CREATED"
            }
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('status is 200/400', function () {",
              "  pm.expect([200, 400]).to.include(pm.response.code);",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Get Notification By Id",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/notifications/{{notificationMongoId}}",
          "host": ["{{baseUrl}}"],
          "path": ["notifications", "{{notificationMongoId}}"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('status is 200/400/404', function () {",
              "  pm.expect([200, 400, 404]).to.include(pm.response.code);",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Update Notification Status",
      "request": {
        "method": "PATCH",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"status\": \"SENT\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/notifications/{{notificationMongoId}}/status",
          "host": ["{{baseUrl}}"],
          "path": ["notifications", "{{notificationMongoId}}", "status"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('status is 200/400/404', function () {",
              "  pm.expect([200, 400, 404]).to.include(pm.response.code);",
              "});"
            ]
          }
        }
      ]
    },
    {
