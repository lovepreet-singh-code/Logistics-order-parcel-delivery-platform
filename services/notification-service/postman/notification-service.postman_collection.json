      "request": {
        "method": "PATCH",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{}"
        },
        "url": {
          "raw": "{{baseUrl}}/notifications/{{notificationMongoId}}/read",
          "host": ["{{baseUrl}}"],
          "path": ["notifications", "{{notificationMongoId}}", "read"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('status is 200/400/404', function () {",
              "  pm.expect([200, 400, 404]).to.include(pm.response.code);",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Soft Delete Notification",
      "request": {
        "method": "DELETE",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/notifications/{{notificationMongoId}}",
          "host": ["{{baseUrl}}"],
          "path": ["notifications", "{{notificationMongoId}}"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('status is 200/400/404', function () {",
              "  pm.expect([200, 400, 404]).to.include(pm.response.code);",
              "});"
            ]
          }
        }
      ]
    }
  ],
  "variable": [
